# ─── Frontend (Next.js) ───────────────────────────────────────
# Next loads env files from this directory (web/), not from the repo root or
# api/. For local dev you usually need nothing here: the browser talks to the
# API through the same-origin /api/* proxy (see next.config.mjs).
#
# To override locally, copy this file to .env.local (git-ignored):
#   cp .env.example .env.local

# Host the /api/* proxy forwards to. Server-side only (not exposed to the
# browser). Point it at the API in other environments (e.g. docker/prod).
API_BASE_URL=http://localhost:8080

# Browser-exposed variables MUST be prefixed with NEXT_PUBLIC_ (none needed today).
# NEXT_PUBLIC_EXAMPLE=
