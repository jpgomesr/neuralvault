{
  "realm": "neuralvault",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "accessTokenLifespan": 300,
  "clients": [
    {
      "clientId": "neuralvault",
      "name": "NeuralVault API",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "neuralvault-dev-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:8080/auth/callback",
        "http://localhost:3000/api/auth/callback"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3000/*"
      },
      "defaultClientScopes": [
        "openid",
        "email",
        "profile"
      ]
    }
  ],
  "users": [
    {
      "username": "dev",
      "enabled": true,
      "emailVerified": true,
      "email": "dev@neuralvault.local",
      "firstName": "Dev",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "dev",
          "temporary": false
        }
      ]
    }
  ]
}
