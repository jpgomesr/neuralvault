# ─── Docker Compose ───────────────────────────────────────────
# Values Docker Compose interpolates into docker-compose.yml. Compose reads a
# .env from this directory automatically, so `cp .env.example .env` is enough
# to override the built-in defaults (all vars below already have defaults).
#
# The application's OWN configuration is separate — see api/.env.example.

# PostgreSQL
POSTGRES_USER=neuralvault
POSTGRES_PASSWORD=neuralvault
POSTGRES_DB=neuralvault
POSTGRES_PORT=5432

# Qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# Ollama
OLLAMA_PORT=11434

# MinIO (object storage)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Keycloak (dev identity provider)
KEYCLOAK_PORT=8081
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
