# ─── Docker Compose ───────────────────────────────────────────
# Values Docker Compose interpolates into docker-compose.yml. Compose reads a
# .env from this directory automatically, so `cp .env.example .env` is enough
# to override the built-in defaults (all vars below already have defaults).
#
# The application's OWN configuration is separate — see api/.env.example.

# PostgreSQL
POSTGRES_USER=neuralvault
POSTGRES_PASSWORD=neuralvault
POSTGRES_DB=neuralvault
POSTGRES_PORT=5432

# Qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# Ollama
OLLAMA_PORT=11434

# Reranker (cross-encoder, via Hugging Face Text Embeddings Inference)
RERANKER_PORT=8082
RERANKER_MODEL=BAAI/bge-reranker-base

# MinIO (object storage)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=neuralvault
MINIO_USE_SSL=false

# Auth
KEYCLOAK_PORT=8081
AUTH_ISSUER_URL=http://localhost:8081/realms/neuralvault
AUTH_CLIENT_ID=neuralvault
AUTH_CLIENT_SECRET=neuralvault-dev-secret
AUTH_REDIRECT_URL=http://localhost:8080/auth/callback
AUTH_SESSION_SECRET=dev-session-secret-change-me-in-production
AUTH_COOKIE_SECURE=false
AUTH_POST_LOGIN_URL=http://localhost:3000
