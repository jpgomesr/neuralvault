# Application configuration for the Go API. Loaded from api/.env (the working
# directory when running `make run` / `go run ./cmd/server`). Copy this file to
# api/.env for local development. Infrastructure/port values must match what
# Docker Compose starts (see the root .env.example).

# ─── Server ───────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_ENV=development
# HTTP hardening: timeouts guard against slow clients; the SSE status stream
# opts out of WRITE_TIMEOUT so long-lived streams survive.
SERVER_READ_HEADER_TIMEOUT=10s
SERVER_READ_TIMEOUT=60s
SERVER_WRITE_TIMEOUT=120s
SERVER_IDLE_TIMEOUT=120s
# Grace period for draining in-flight connections on SIGINT/SIGTERM.
SERVER_SHUTDOWN_TIMEOUT=20s
# Max upload request body in bytes (default 100 MiB).
SERVER_MAX_UPLOAD_BYTES=104857600

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USERNAME=neuralvault
POSTGRES_PASSWORD=neuralvault
POSTGRES_NAME=neuralvault
POSTGRES_SSL_MODE=disable
POSTGRES_MAXCONNS=10
POSTGRES_MINCONNS=2

# ─── Qdrant ───────────────────────────────────────────────────
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=localhost
QDRANT_USE_TLS=false
QDRANT_API_KEY=local
QDRANT_COLLECTION_NAME=neuralvault
QDRANT_VECTOR_SIZE=768

# ─── Ollama ───────────────────────────────────────────────────
OLLAMA_PORT=11434
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_COMPLETION_MODEL=llama3

# ─── MinIO (object storage) ───────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=neuralvault
MINIO_USE_SSL=false

# ─── Auth (OIDC) ──────────────────────────────────────────────
# Standard OIDC discovery — swap the issuer/client to use any provider.
# Dev defaults point at the bundled Keycloak realm (see docker-compose.yml).
AUTH_ISSUER_URL=http://localhost:8081/realms/neuralvault
AUTH_CLIENT_ID=neuralvault
AUTH_CLIENT_SECRET=neuralvault-dev-secret
AUTH_REDIRECT_URL=http://localhost:8080/auth/callback
# Signs the session cookie (HMAC-SHA256); must be at least 32 bytes. Rotate in prod.
AUTH_SESSION_SECRET=dev-session-secret-change-me-in-production
AUTH_COOKIE_SECURE=false
AUTH_POST_LOGIN_URL=http://localhost:3000
